# API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL_DEV=claude-3-haiku-20240307
LLM_MODEL_PROD=claude-3-5-sonnet-20241022

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
VECTOR_DB_TYPE=chromadb
VECTOR_DB_PATH=./chroma_db
CACHE_DB_PATH=./data/cache.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# UI Configuration
UI_HOST=0.0.0.0
UI_PORT=7860
UI_SHARE=false

# Processing Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVAL_DOCS=5
TEMPERATURE=0.1

# Cost Controls
MAX_TOKENS_PER_REQUEST=4000
ENABLE_CACHING=true
CACHE_TTL_HOURS=24

# Optional: Qdrant Configuration (if using Docker)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION_NAME=powerbi_rag